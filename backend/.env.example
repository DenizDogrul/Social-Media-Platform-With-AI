SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
APP_ENV=development
DATABASE_URL=sqlite:///./test.db
TEST_DATABASE_URL=sqlite:///./test_suite.db
DB_BACKUP_ON_START=1
DB_BACKUP_DIR=./backups
DB_BACKUP_KEEP=14
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AMBIENT_INGEST_KEY=
FOLLOWED_FEED_RATIO=0.7

# Storage backend: local | cloudinary
STORAGE_BACKEND=local
MEDIA_BASE_URL=/media
MEDIA_UPLOAD_ROOT=uploads

# Cloudinary (required only when STORAGE_BACKEND=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=nebula